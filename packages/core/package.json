{
  "name": "boxes-core",
  "description": "Core graph editor library powered by Cytoscape.js",
  "type": "module",
  "main": "./dist/boxes-core.umd.js",
  "module": "./dist/boxes-core.js",
  "exports": {
    ".": {
      "import": "./dist/boxes-core.js",
      "require": "./dist/boxes-core.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "cytoscape": "^3.28.1",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-edgehandles": "^4.0.1",
    "cytoscape-euler": "^1.2.3",
    "cytoscape-klay": "^3.1.4",
    "cytoscape-pdf-export": "^0.0.3",
    "cytoscape-popper": "^4.0.1",
    "dagre": "^0.8.5",
    "n3": "^2.0.3",
    "rdflib": "^2.3.6"
  },
  "devDependencies": {
    "happy-dom": "^13.6.2",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpmccu/boxes",
    "directory": "packages/core"
  }
}
