{
  "name": "@boxes/electron",
  "version": "0.1.2",
  "description": "Standalone Electron desktop app for Boxes graph editor",
  "author": "Boxes Contributors",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "echo 'Electron app does not need build step. Use build:dist to create distributables.'",
    "build:dist": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@boxes/core": "file:../core"
  },
  "devDependencies": {
    "electron": "28.2.4",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.boxes.editor",
    "productName": "Boxes",
    "files": [
      "**/*",
      "!node_modules",
      "!src",
      "!tests"
    ],
    "directories": {
      "output": "dist"
    },
    "electronVersion": "28.2.4"
  }
}
